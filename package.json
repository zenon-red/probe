{
  "name": "@zenon-red/probe",
  "version": "1.3.5",
  "description": "All-in-one CLI tool for interacting with Nexus.",
  "homepage": "https://zenon.red",
  "bugs": {
    "url": "https://github.com/zenon-red/probe/issues"
  },
  "license": "MIT",
  "author": "ZŌE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenon-red/probe.git"
  },
  "bin": {
    "probe": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "npm run generate:decoders && tsdown",
    "pretest": "npm run generate:decoders",
    "pretest:ci": "npm run generate:decoders",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test tests/unit && npm run test:hermes && npm run test:opencode",
    "test:hermes": "npx tsx --test tests/node/harness-usage-hermes.test.ts",
    "test:opencode": "npx tsx --test tests/node/harness-usage-opencode.test.ts",
    "test:dist-version": "npx tsx --test tests/node/probe-version-dist.test.ts",
    "test:ci": "bun test tests/unit/*.test.ts && npm run test:hermes && npm run test:opencode",
    "test:adapters": "bun test tests/unit/harness-usage-adapters.test.ts",
    "test:watch": "bun test --watch",
    "lint": "bun x oxlint src/",
    "pretypecheck": "npm run generate:decoders",
    "typecheck": "tsc --noEmit",
    "check:skills-ref": "npx tsx scripts/check-skills-ref.ts tests/fixtures/genesis/zenon-red.manifest.json",
    "check:push": "npm run generate:decoders && npm run typecheck && npm run lint && npm run build && npm run test:dist-version && npm run check:skills-ref -- --strict",
    "generate:decoders": "npx tsx scripts/generate-decoders.ts",
    "lint:staged": "lint-staged",
    "lint:commit": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "@toon-format/toon": "^2.3.0",
    "c12": "^2.0.0",
    "canonical-json": "^0.4.0",
    "citty": "^0.2.2",
    "spacetimedb": "^2.2.0",
    "znn-typescript-sdk": "https://codeload.github.com/PlasmaKing/znn-typescript-sdk/tar.gz/865bc8866d798893ed364f6db4f14162efe0b396"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "node-fetch-native": "1.6.6"
  },
  "lint-staged": {
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{ts,tsx}": [
      "oxlint"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.13.0"
  },
  "packageManager": "npm@11.13.0"
}
