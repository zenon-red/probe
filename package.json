{
  "name": "@zenon-red/probe",
  "version": "1.2.7",
  "description": "All-in-one CLI tool for interacting with Nexus.",
  "homepage": "https://zenon.red",
  "bugs": {
    "url": "https://github.com/zenon-red/probe/issues"
  },
  "license": "MIT",
  "author": "ZŌE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenon-red/probe.git"
  },
  "bin": {
    "probe": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "tsdown",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test",
    "test:ci": "bun test tests/unit/config.test.ts tests/unit/sql.test.ts",
    "test:watch": "bun test --watch",
    "lint": "bun x oxlint src/",
    "typecheck": "tsc --noEmit",
    "check:push": "npm run typecheck && npm run lint && npm run build",
    "generate:decoders": "npx tsx scripts/generate-decoders.ts",
    "lint:staged": "lint-staged",
    "lint:commit": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@toon-format/toon": "^2.1.0",
    "c12": "^2.0.0",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "kolorist": "^1.8.0",
    "spacetimedb": "^2.0.1",
    "znn-typescript-sdk": "https://codeload.github.com/PlasmaKing/znn-typescript-sdk/tar.gz/865bc8866d798893ed364f6db4f14162efe0b396"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.13",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.48.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "node-fetch-native": "1.6.6"
  },
  "lint-staged": {
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{ts,tsx}": [
      "oxlint"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.13.0"
}
